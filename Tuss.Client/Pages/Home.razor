@page "/"
@inject HttpClient Http

<PageTitle>Ladda upp fil</PageTitle>

<h1>Ladda upp fil</h1>

<p>Välj en fil och klicka på knappen för att skicka den med <code>POST</code> till servern.</p>

<div class="mb-3">
    <label class="form-label">Fil</label>
    <InputFile OnChange="OnFileSelected" class="form-control" />
</div>

<div class="mb-3">
    <label class="form-label">Filnamn på servern</label>
    <input class="form-control" @bind="targetFileName" />
</div>

<button class="btn btn-primary" @onclick="UploadAsync" disabled="@(!CanUpload)">
    @(isUploading ? "Laddar upp..." : "Ladda upp")
</button>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <p class="mt-3">@statusMessage</p>
}

@code {
    private IBrowserFile? selectedFile;
    private string targetFileName = string.Empty;
    private string statusMessage = string.Empty;
    private bool isUploading;

    // Keep this starter example memory-safe by capping files to 20 MB.
    private const long MaxFileSizeBytes = 20 * 1024 * 1024;

    private bool CanUpload => selectedFile is not null && !string.IsNullOrWhiteSpace(targetFileName) && !isUploading;

    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        targetFileName = selectedFile.Name;
        statusMessage = $"Vald fil: {selectedFile.Name} ({selectedFile.Size} bytes)";
    }

    private async Task UploadAsync()
    {
        if (selectedFile is null || string.IsNullOrWhiteSpace(targetFileName))
        {
            statusMessage = "Välj en fil först.";
            return;
        }

        try
        {
            isUploading = true;
            statusMessage = "Laddar upp...";

            await using var stream = selectedFile.OpenReadStream(MaxFileSizeBytes);
            using var content = new StreamContent(stream);
            content.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue("application/octet-stream");

            var safeName = Uri.EscapeDataString(targetFileName.Trim());
            var response = await Http.PostAsync($"/api/files/{safeName}", content);

            statusMessage = response.StatusCode switch
            {
                System.Net.HttpStatusCode.OK => "Uppladdning klar.",
                System.Net.HttpStatusCode.Conflict => "Filen finns redan (409).",
                _ => $"Fel vid uppladdning: {(int)response.StatusCode} {response.ReasonPhrase}"
            };
        }
        catch (IOException)
        {
            statusMessage = $"Filen är för stor. Max {MaxFileSizeBytes / (1024 * 1024)} MB i detta exempel.";
        }
        catch (Exception ex)
        {
            statusMessage = $"Tekniskt fel: {ex.Message}";
        }
        finally
        {
            isUploading = false;
        }
    }
}
